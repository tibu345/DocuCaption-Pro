# Optional: configure this only in .env for the backend.
# Do not commit real keys or expose them through Vite client environment variables.
CAPTION_PROVIDER="gemini"
GEMINI_API_KEY="your_backend_only_gemini_key"
GEMINI_MODEL="gemini-2.0-flash"

# Frontend auth. Create a Supabase project, enable Email and Google provider,
# then add these public browser-safe values.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_public_anon_key"
VITE_PERSIST_UPLOADED_DOCS="false"

# Frontend deployment.
# Leave VITE_API_BASE_URL empty for local Vite proxy. Set it to your hosted backend URL for GitHub Pages.
VITE_API_BASE_URL=""
# For GitHub Pages project sites, set this to "/your-repo-name/" in the deployment environment.
VITE_BASE_PATH="/"
# Backend-only Supabase access for profile creation and metered writes.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Local generated-caption alternative
# CAPTION_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:1b"

# Optional backend settings
PORT=8787
CLIENT_ORIGIN="http://localhost:3000"
PRODUCTION_ORIGIN="https://your-production-domain.com"
ALLOW_UNAUTHENTICATED_CAPTION_TESTING="true"
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
STRIPE_CHECKOUT_PLACEHOLDER_URL="https://checkout.stripe.com/stub"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
